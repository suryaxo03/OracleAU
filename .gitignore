# ================================================================
# OracleAU — .gitignore
# ================================================================

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
venv/
env/
.env/
oracleau/          # conda env if named same as project

# Environment variables (never commit secrets)
.env
.env.local

# Data files — too large and regenerated by data_pipeline.py
data/
reports/plots/
reports/*.txt

# Keep reports directory itself (but not contents)
!reports/.gitkeep

# Jupyter
.ipynb_checkpoints/
*.ipynb

# macOS
.DS_Store
.AppleDouble
.LSOverride

# IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
uvicorn.log

# ================================================================
# WHAT IS COMMITTED:
#   index.html
#   api.py
#   data_pipeline.py
#   model_training_v2.py
#   requirements.txt
#   render.yaml
#   README.md
#   models/          ← pkl + h5 + scalers (needed by API on Render)
# ================================================================